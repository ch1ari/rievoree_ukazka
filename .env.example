# Copy to .env.local and fill in. For local dev, `supabase start` prints both
# values (API URL + anon key). NEVER put the service_role key in frontend env.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# --- ETL worker (docker-compose) ---------------------------------------------
# The worker downloads uploaded files from Storage with the service_role key
# (server-side only — never expose it to the frontend). `supabase status -o env`
# prints SERVICE_ROLE_KEY for local dev.
WORKER_SERVICE_ROLE_KEY=your-local-service-role-key
# Optional overrides:
# WORKER_SUPABASE_URL=http://host.docker.internal:54321
# WORKER_POLL_MS=2000
# WORKER_ID=etl-worker-1

# --- Connectors: Google Drive OAuth (edge function secrets) -------------------
# Set with `supabase secrets set ...` (remote) or in supabase/functions/.env
# (local: `supabase functions serve --env-file`). These power the gdrive
# connector's data-access OAuth app (Drive read-only), SEPARATE from login OAuth.
#   GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
#   GOOGLE_OAUTH_CLIENT_SECRET=...
#   GOOGLE_OAUTH_REDIRECT_URI=https://<project-ref>.supabase.co/functions/v1/connector-callback
#   GOOGLE_OAUTH_APP_REDIRECT=https://your-frontend/connectors   # where the browser returns
# Local equivalents:
#   GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:54321/functions/v1/connector-callback
#   GOOGLE_OAUTH_APP_REDIRECT=http://127.0.0.1:3000/connectors

# --- Social login providers (Supabase Auth) ----------------------------------
# Enable "Sign in with Google / GitHub". These are read by config.toml.
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID / SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET
#   SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID / SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET

# --- Connector auto-sync (pg_cron + pg_net, optional) ------------------------
# Provision these Vault secrets so the bounded cron can call connector-sync:
#   edge_connector_sync_url  = https://<project-ref>.supabase.co/functions/v1/connector-sync
#   edge_service_role_key    = <service_role JWT>   (reused from notify-review)
# See DB-COMMANDS.md for the exact vault.create_secret statements.
